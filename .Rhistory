for(i in 1:n){
log_w <- rep(NA, K)
for(k in 1:K){
log_w[k] <- -(1/2)*(y[i] - mu[k])^2  + (-1/(2*sigma_mu2)) * mu[k]^2
}
log_w <- log_w - max(log_w)
w <- exp(log_w) / sum(exp(log_w))
c_index <- sample(1:K, 1, prob = w)
C[i,c_index] <- 1
}
for(k in 1:K){
n_k <- sum(C[,k])
if(n_k > 0){
y_bar_k <- t(y) %*% C[,k] / n_k
mu_post_mean <- n_k * y_bar_k / (n_k + 1/sigma_mu2)
mu_post_var <- 1/(n_k + 1/sigma_mu2)
