gibbs_gaussian_mix <- function(n, n_iter, n_burn, C_init, mu_init, y, sigma_mu2){
comp_time <- system.time({
K <- length(mu_init)
mu_hist <- matrix(data = NA, nrow = n_iter, ncol = K)
