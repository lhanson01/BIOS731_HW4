mu_hist[iter,] <- mu
C_hist[iter, , ] <- C
}
post_means <- colMeans(mu_hist[(n_burn+1):n_iter, ], na.rm = TRUE)
mu_CIs <- apply(mu_hist[(n_burn+1):n_iter, ], MARGIN = 2,
